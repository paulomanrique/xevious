0106   0000             
0107   0000             ; prepareVolume
0108   0000             ; -------------
0109   0000             ; HL  <-  ?
0110   0000             ; A   <-  ?
0111   0000             ; B   <-  point to volume LUT (high part)
0112   0000             ;
0113   0000             ; prepare B for volume ajustement
0114   0000             ; = 28 cycles
0115   0000             
0116   0000                         macro prepareVolume ch
0117   0000~            
0118   0000~                        LD      HL, WAVVOL+ch       ; point to volume info  ' 10
0119   0000~                        LD      A, (HL)             ; A = volume            ' 7
0120   0000~                        OR      $10                 ; ajusted for LUT       ' 7
0121   0000~                        LD      B, A                ; save to B             ' 4
0122   0000~            
0123   0000                         endm                        ;                       ' 28
0124   0000             
0125   0000             
0126   0000             ; prepareChannel
0127   0000             ; --------------
0128   0000             ; SP  <-  point to the sample source
0129   0000             ; HL  <-  point to write buffer
0130   0000             ; A   <-  ?
0131   0000             ; E   <-  ?
0132   0000             ;
0133   0000             ; set bank and prepare registers to play channel 'ch'
0134   0000             ; = 182 cycles
0135   0000             
0136   0000                         macro prepareChannel ch
0137   0000~            
0138   0000~                        LD      HL, IWAVADR+(ch*4)  ; point to sample adr   ' 10
0139   0000~                        LD      A, (HL)             ; A = bit 8-15          ' 7
0140   0000~                        LD      E, A                ; save to E             ' 4
0141   0000~                        INC     L                   ;                       ' 4
0142   0000~                        RLA                         ; C flag = bit 15       ' 4
0143   0000~                        LD      A, (HL)             ; A = bit 16-23         ' 7
0144   0000~                        RLA                         ; A = bit 15-22         ' 4     (40)
0145   0000~                        setBankFast                 ; set bank              ' 97    (137)
0146   0000~            
0147   0000~                        LD      A, E                ; A = bit 8-15          ' 4
0148   0000~                        OR      $80                 ; A = $80 | bit 8-14    ' 7
0149   0000~                        LD      H, A                ;                       ' 4
0150   0000~                        XOR     A                   ;                       ' 4
0151   0000~                        LD      L, A                ; L = $00               ' 4
0152   0000~                        LD      SP, HL              ; SP = sample src       ' 6
0153   0000~                        LD      HL, (WRITEBUF)      ;                       ' 16    (182)
0154   0000~            
0155   0000                         endm                        ;                       ' 182
0156   0000             
0157   0000             
0158   0000             ; updateChannelData
0159   0000             ; -----------------
0160   0000             ; HL  <-  ?
0161   0000             ;
0162   0000             ; update sample address and sample lenght
0163   0000             ; = 76 cycles
0164   0000             
0165   0000                         macro updateChannelData ch
0166   0000~            
0167   0000~                        LD      HL, (IWAVADR+(ch*4))    ; increment address ' 16
0168   0000~                        INC     HL                      ;                   ' 6
0169   0000~                        LD      (IWAVADR+(ch*4)), HL    ;                   ' 16    (38)
0170   0000~            
0171   0000~                        LD      HL, (IWAVLEN+(ch*4))    ; decrement lenght  ' 16
0172   0000~                        DEC     HL                      ;                   ' 6
0173   0000~                        LD      (IWAVLEN+(ch*4)), HL    ;                   ' 16    (76)
0174   0000~            
0175   0000                         endm
0176   0000             
0177   0000             ; checkChannelEnd
0178   0000             ; ---------------
0179   0000             ; HL  <-  ?
0180   0000             ; A   <-  ?
0181   0000             ;
0182   0000             ; check is sample is done, restart it if needed
0183   0000             ; = 180 cycles
0184   0000             
0185   0000                         macro checkChannelEnd ch
0186   0000~            
0187   0000~                        LD      HL, (IWAVLEN+(ch*4))    ; get sample lenght ' 16
0188   0000~                        LD      A, H                    ;                   ' 4
0189   0000~                        OR      L                       ;                   ' 4
0190   0000~                        JP      Z, .done                ; sample done ?     ' 10    (34)
0191   0000~            
0192   0000~                        wait136                         ;                   ' 136   (170)
0193   0000~                        JP      .end                    ;                   ' 10    (180)
0194   0000~            
0195   0000~            .done
0196   0000~                        getLoopStatus ch            ; loop play ?           ' 22    (56)
0197   0000~                        JP      Z, .stop            ;                       ' 10    (66)
0198   0000~            
0199   0000~                        copyChannelParams ch        ; copy params           ' 64    (130)
0200   0000~                        wait40                      ;                       ' 40
0201   0000~                        JP      .end                ;                       ' 10    (180)
0202   0000~            
0203   0000~            .stop
0204   0000~                        stopChannel ch              ;                       ' 114   (180)
0205   0000~            
0206   0000~            .end
0207   0000                         endm                        ;                       ' 180
