0051   0000             ; copyChannelParams
0052   0000             ; -----------------
0053   0000             ; copy channel parameters to internal structure
0054   0000             ; = 64 cycles
0055   0000             
0056   0000                         macro copyChannelParams ch
0057   0000~            
0058   0000~                        LD      HL, (WAVADR+(ch*4))     ;                   ' 16
0059   0000~                        LD      (IWAVADR+(ch*4)), HL    ;                   ' 16
0060   0000~                        LD      HL, (WAVLEN+(ch*4))     ;                   ' 16
0061   0000~                        LD      (IWAVLEN+(ch*4)), HL    ;                   ' 16
0062   0000~            
0063   0000                         endm                            ;                   ' 64
0064   0000             
0065   0000             ; stopChannel
0066   0000             ; -----------
0067   0000             ; set null sample play for channel 'ch'
0068   0000             ; = 114 cycles
0069   0000             
0070   0000                         macro stopChannel ch
0071   0000~            
0072   0000~                        LD      HL, (NULLWAVADR)        ;                   ' 16
0073   0000~                        LD      (IWAVADR+(ch*4)), HL    ;                   ' 16
0074   0000~                        LD      HL, (NULLWAVLEN)        ;                   ' 16
0075   0000~                        LD      (IWAVLEN+(ch*4)), HL    ;                   ' 16
0076   0000~                        clearPlayStatus ch              ; clear play status ' 25
0077   0000~                        clearLoopStatus ch              ; clear loop status ' 25
0078   0000~            
0079   0000                         endm                            ;                   ' 114
