0351+  0000             ; wait2p16x
0352+  0000             ; ---------
0353+  0000             ; wait for ((w * 16) + 2) cycles
0354+  0000             ;
0355+  0000                         macro   wait2p16x w
0356+  0000~            
0357+  0000~                        LD      A, w            ; 7-2
0358+  0000~            .loop
0359+  0000~                        DEC     A               ; 4
0360+  0000~                        JR      NZ, .loop       ; 12
0361+  0000~            
0362+  0000                         endm
