0367   0000                         macro readAndMix2
0368   0000~            
0369   0000~                        POP     DE              ; read 2 samples from ROM   ' 10+2
0370   0000~            
0371   0000~                        LD      C, E            ; first sample              ' 4     |
0372   0000~                        doEnvAndMix             ;                           ' 35    | 78 (90)
0373   0000~                        LD      C, D            ; second sample             ' 4     |
0374   0000~                        doEnvAndMix             ;                           ' 35    |
0375   0000~            
0376   0000                         endm                    ;                           ' 90 (+14/+28)
