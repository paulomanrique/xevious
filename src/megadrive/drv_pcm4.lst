0210   0000             ; swapBuffer
0211   0000             ; ----------
0212   0000             ; HL  <-  point to new write buffer
0213   0000             ; DE  <-  point to new read buffer
0214   0000             ;
0215   0000             ; switch read and write buffer
0216   0000             ; = 72 cycles
0217   0000             
0218   0000                         macro swapBuffer
0219   0000~            
0220   0000~                        LD      HL, (WRITEBUF)      ;                       ' 16
0221   0000~                        LD      DE, (READBUF)       ;                       ' 20
0222   0000~                        LD      (WRITEBUF), DE      ;                       ' 20
0223   0000~                        LD      (READBUF), HL       ;                       ' 16
0224   0000~            
0225   0000                         endm                        ;                       ' 72
0226   0000             
0227   0000             
0228   0000             ; sampleOutput
0229   0000             ; ------------
0230   0000             ; HL'  -> YMPORT1
0231   0000             ; BC' <-> point to play output buffer
0232   0000             ; D    -> $80
0233   0000             ;
0234   0000             ; output a sample to the DAC
0235   0000             ; = 30 cycles
0236   0000             
0237   0000                         macro sampleOutput
0238   0000~            
0239   0000~                        EXX                     ;                           ' 4
0240   0000~                        LD      A, (BC)         ; read sample from buffer   ' 7
0241   0000~                        ADD     D               ; unsign                    ' 4
0242   0000~                        INC     C               ; increment with looping    ' 4
0243   0000~                        LD      (HL), A         ; play sample               ' 7
0244   0000~                        EXX                     ;                           ' 4
0245   0000~            
0246   0000                         endm                    ;                           ' 30
0247   0000             
0248   0000             
0249   0000             ; doEnvAndClear
0250   0000             ; = 18 cycles
0251   0000             
0252   0000                         macro doEnvAndClear
0253   0000~            
0254   0000~                        LD      A, (BC)         ; compute volume            ' 7
0255   0000~                        LD      (HL), A         ; write in output buffer    ' 7
0256   0000~                        INC     L               ; next                      ' 4
0257   0000~            
0258   0000                         endm
0259   0000             
0260   0000             ; readAndClear2
0261   0000             ; -------------
0262   0000             ; SP  <-> point to the sample source (ROM)
0263   0000             ; HL  <-> point to the write output buffer
0264   0000             ; BC   -> point to envelop LUT
0265   0000             ; DE  <-  ?
0266   0000             ;
0267   0000             ; read 2 samples from the ROM, apply volume
0268   0000             ; and write them in output buffer
0269   0000             ; = 56 cycles
0270   0000             
0271   0000                         macro readAndClear2
0272   0000~            
0273   0000~                        POP     DE              ; read 2 samples from ROM   ' 10+2
0274   0000~                        LD      C, E            ; first sample              ' 4
0275   0000~                        doEnvAndClear           ;                           ' 18
0276   0000~                        LD      C, D            ; second sample             ' 4
0277   0000~                        doEnvAndClear           ;                           ' 18
0278   0000~            
0279   0000                         endm                    ;                           ' 56
