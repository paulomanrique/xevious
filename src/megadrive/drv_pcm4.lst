0281   0000             
0282   0000             ; readAndClear20WhilePlay3
0283   0000             ; ------------------------
0284   0000             ; SP  <-> point to the sample source (ROM)
0285   0000             ; HL  <-> point to the write output buffer
0286   0000             ; BC   -> point to envelop LUT
0287   0000             ; DE  <-  ?
0288   0000             ;
0289   0000             ; read 20 samples from the ROM, apply volume
0290   0000             ; and write them in output buffer while playing 3 samples
0291   0000             ; = 666 cycles
0292   0000             
0293   0000                         macro readAndClear20WhilePlay3
0294   0000~            
0295   0000~                        ; 1 --------------------
0296   0000~            
0297   0000~                        sampleOutput            ;                           ' 30
0298   0000~            
0299   0000~                        readAndClear2           ;                           ' 56    |
0300   0000~                        readAndClear2           ;                           ' 56    | 168 (198)
0301   0000~                        readAndClear2           ;                           ' 56    |
0302   0000~            
0303   0000~                        ; 4 --------------------
0304   0000~            
0305   0000~                        POP     DE              ; read 2 samples from ROM   ' 10+2  |
0306   0000~                        LD      C, E            ; first sample              ' 4     | 25 (223)
0307   0000~                        wait9                   ; synchro                   ' 9     |
0308   0000~            
0309   0000~                        sampleOutput            ; (1*223)+0 --> perfect     ' 30 (253)
0310   0000~            
0311   0000~                        doEnvAndClear           ;                           ' 18    |
0312   0000~                        LD      C, D            ; second sample             ' 4     | 40 (293)
0313   0000~                        doEnvAndClear           ;                           ' 18    |
0314   0000~            
0315   0000~                        readAndClear2           ;                           ' 56    | 112 (405)
0316   0000~                        readAndClear2           ;                           ' 56    |
0317   0000~            
0318   0000~                        ; 7 --------------------
0319   0000~            
0320   0000~                        POP     DE              ; read 2 samples from ROM   ' 10+2  |
0321   0000~                        LD      C, E            ; first sample              ' 4     | 34 (446)
0322   0000~                        doEnvAndClear           ;                           ' 18    |
0323   0000~                        wait7                   ; synchro                   ' 7     |
0324   0000~            
0325   0000~                        sampleOutput            ; (2*223)+0 --> perfect     ' 30 (476)
0326   0000~            
0327   0000~                        LD      C, D            ; second sample             ' 4     | 22 (498)
0328   0000~                        doEnvAndClear           ;                           ' 18    |
0329   0000~            
0330   0000~                        readAndClear2           ;                           ' 56    |
0331   0000~                        readAndClear2           ;                           ' 56    | 168 (666)
0332   0000~                        readAndClear2           ;                           ' 56    |
0333   0000~            
0334   0000                         endm                    ;                           ' 666
