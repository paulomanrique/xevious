0336   0000             
0337   0000             ; doEnvAndMix
0338   0000             ; = 35 --> 49 cycles
0339   0000             
0340   0000                         macro doEnvAndMix
0341   0000~            
0342   0000~                        LD      A, (BC)         ; compute volume            ' 7     |
0343   0000~                        ADD     (HL)            ; mix                       ' 7     | 24
0344   0000~                        JP      PO, .ok         ; check overflow            ' 10    |
0345   0000~            
0346   0000~                        LD      A, $7F          ; fix overflow              ' 7     |
0347   0000~                        ADC     $0              ; A = $7F/$80               ' 7     | +14
0348   0000~            
0349   0000~            .ok
0350   0000~                        LD      (HL), A         ; write sample in buffer    ' 7     | 11 (35)
0351   0000~                        INC     L               ; next                      ' 4     |
0352   0000~            
0353   0000                         endm
