0430   0000             ; ###########################       init       ##############################
0431   0000             
0432   0000                         ORG     $0000
0433   0000             
0434   0000             init
0435   0000 F3                      DI                      ; disable ints
0436   0001 31 00 0E                LD      SP, $0E00       ; setup stack
0437   0004 ED 56                   IM      $01             ; set int mode 1
0438   0006 AF                      XOR     A
0439   0007 32 02 01                LD      (STATUS), A     ; driver not ready
0440   000A 32 00 01                LD      (COMMAND), A    ; command cleared
0441   000D C3 00 02                JP      start           ; jump to start
0442   0010             
0443   0010             
0444   0010             ; ###########################     interrupt    ##############################
0445   0010             
0446   0010 00                      BLOCK   $0038-$
0447   0038             
0448   0038             interrupt                           ; do nothing in this program
0449   0038 ED 4D                   RETI
0450   003A             
0451   003A             
0452   003A             ; ###########################       main       ##############################
0453   003A             
0454   003A 00                      BLOCK   $0200-$
0455   0200             
0456   0200             start
0457   0200 21 04 01                LD      HL, PARAMS
0458   0203 3E 00                   LD      A, $00
0459   0205 06 20                   LD      B, $20
0460   0207             
0461   0207             cp_loop
0462   0207 77                      LD      (HL), A         ; clear sample parameters
0463   0208 23                      INC     HL
0464   0209 10 FC                   DJNZ    cp_loop
0465   020B             
