0082   0000             ; handlePlayCommand
0083   0000             ; -----------------
0084   0000             ; HL  <-  ?
0085   0000             ; DE  <-  ?
0086   0000             ;
0087   0000             ; handle play command for channel 'ch'
0088   0000             ; = 146 cycles
0089   0000             
0090   0000                         macro handlePlayCommand ch
0091   0000~            
0092   0000~                        getPlayCommand ch           ; play command ?        ' 22
0093   0000~                        JP      NZ, .do_command     ;                       ' 10    (32)
0094   0000~            
0095   0000~                        wait104                     ;                       ' 104   (136)
0096   0000~                        JP      .end                ;                       ' 10    (146)
0097   0000~            
0098   0000~            .do_command
0099   0000~                        clearPlayCommand ch         ; clear play command    ' 25    (57)
0100   0000~                        copyChannelParams ch        ; copy params           ' 64
0101   0000~                        setPlayStatus ch            ; set play status       ' 25
0102   0000~            
0103   0000~            .end
0104   0000                         endm                        ;                       ' 146
