 109               	check_for_extra_solvalou: | $133A
 110 009e 6100 1502 	    jbsr       display_player_scores
 111               	    *** There is a call to a protection check routine here
 112 00a2 4A39 0000 	    tst.b     (bonus_life_none)
 112      0000 
 113 00a8 6600 009C 	    jne     9f
 114               	    ** Another Xevious jUG **
 115               	    ** whenever next_bonus_life_Ks is less than curr_player_score_Ks
 116               	    ** (which will be the case when eg. score=9,999,990)
 117               	    ** then C is never set, and an extra Solvalou is awarded
 118               	    ** every time this routine is called (points are added to the score)    
 119 00ac 3239 0000 	    move.w    (next_bonus_life_Ks),d1
 119      0000 
 120 00b2 3039 0000 	    move.w    (curr_player_score_msb),d0        | swapped, Ks in Z80
 120      0000 
 121 00b8 9041      	    sub.w     d1,d0
 122 00ba D041      	    add.w     d1,d0                             | reached next bonus word?
 123 00bc 6500 0088 	    jcs     9f                                | no, exit
 124 00c0 1039 0000 	    move.b    (dswa),d0
 124      0000 
 125 00c6 E718      	    rol.b     #3,d0
 126 00c8 0240 0003 	    and.w     #3,d0                             | starting lives setting
 127 00cc 6704      	    jeq     1f                                | 5, skip
 128 00ce 303C 0001 	    move.w    #1,d0                             | use 2nd table
 129 00d2 41FA 1498 	1:  lea       bonus_tbl_ptrs,a0
 130               		.ifdef	NO68020
 131 00d6 D040      	    add.w     d0,d0
 132 00d8 D040      	    add.w     d0,d0                             | x4 (entry offset)
 133 00da 2070 0000 	    move.l    (a0,d0.w),a0                      | table address
 134               	    .else
 135               	    * x4 (entry offset)
 136               	    move.l    (a0,d0.w*4),a0                      | table address
 137               	    .endif
 138 00de 1039 0000 	    move.b    (dswa),d0
 138      0000 
 139 00e4 4600      	    not.b     d0
 140 00e6 E418      	    ror.b     #2,d0
 141 00e8 0240 0007 	    and.w     #7,d0                             | bonus life setting
 142               	    * x2 (entry offset)
 143               	 	.ifdef	NO68020
 144 00ec D040      	    add.w     d0,d0                             | x2 (entry offset)
 145 00ee 3230 0000 	    move.w    (a0,d0.w),d1                      | addition for next bonus
 146               	    .else
 147               	    move.w    (a0,d0.w*2),d1                      | addition for next bonus
 148               	    .endif
 149               	    * this handles the 20K, 60K, every 60K situation
 150               	    * when bonus is 20K, and addition is 60K,
