  59               	
  60               	* offsets into object table
  61               	    .equ  _STATE,     0
  62               	    .equ  _ATTR,      1
  63               	    .equ  _EXTRA,     4
  64               	    .equ  _X,         8
  65               	    .equ  _dX,        10
  66               	    .equ  _ddX,       12
  67               	    .equ  _Y,         14
  68               	    .equ  _dY,        16
  69               	    .equ  _ddY,       18
  70               	    .equ  _CODE,      20
  71               	    .equ  _COLOUR,    21
  72               	    .equ  _PTS,       22
  73               	    .equ  _TIMER,     24
  74               	    .equ  _TIMER1,    25
  75               	      .equ  _NVEC,    25
  76               	    .equ  _TIMER2,    26
  77               	      .equ  _VECLEN,  26
  78               	    .equ  _FFREQ,     28
  79               	    .equ  _TYPE,      30
  80               	
  81               	    .equ  _OBJSIZE,   32
  82               	
  83               	* video functions
  84               	    .equ  BANK_FG_COLORRAM,   (0<<2)
  85               	    .equ  BANK_BG_COLORRAM,   (1<<2)
  86               	    .equ  BANK_FG_VIDEORAM,   (2<<2)
  87               	    .equ  BANK_BG_VIDEORAM,   (3<<2)
  88               	
  89               	* sound ordinals
  90               	
  91               	    .equ  MAIN_THEME_SND,         0x01
  92               	    .equ  HIGHEST_SCORE_SND,      0x02
  93               	    .equ  HIGH_SCORE_SND,         0x03
  94               	    .equ  EXTRA_SOLVALOU_SND,     0x04
  95               	    .equ  FLYING_ENEMY_HIT_SND,   0x05
  96               	    .equ  GARU_ZAKATO_SND,        0x06
  97               	    .equ  ANDOR_GENESIS_SND,      0x07
  98               	    .equ  SHEONITE_SND,           0x08
  99               	    .equ  TELEPORT_SND,           0x09
 100               	    .equ  BACURA_HIT_SND,         0x0a
 101               	    .equ  SHOT_SND,               0x0b
 102               	    .equ  BOMB_SND,               0x0c
 103               	    .equ  BONUS_FLAG_SND,         0x0d
 104               	    .equ  SOLVALOU_SND,           0x0e
 105               	    * 60XX (noise chip?)
 106               	    .equ  COIN_SND,               0x10
 107               	    .equ  GROUND_EXPLOSION_SND,   0x11
 108               	    .equ  SOLVALOU_EXPLOSION_SND, 0x12
