  10               	    OPT_DISABLE_BG_LAYER=0              | don't change values here!
  11               	    OPT_DISABLE_SPRITES=0               | don't change values here!
  12               	    OPT_DISABLE_DISPLAY_MASKS=0         | don't change values here!
  13               											| don't change values here!
  14               	    * optimisation options              | don't change values here!
  15               	    OPT_SUB_HAS_IRQ=1                   | don't change values here!
  16               	    * game test options                 | don't change values here!
  17               	    OPT_START_AREA=1    | 1-16          | don't change values here!
  18               	    OPT_LOOP_AREA=0                     | don't change values here!
  19               	    OPT_INVINCIBLE=0                    | don't change values here!
  20               	    OPT_INFINITE_LIVES=0                | don't change values here!
  21               	    * score is BCD format               | don't change values here!
  22               	    OPT_START_SCORE=0x0000000           | don't change values here!
  23               	    OPT_ENABLE_HIGH_SCORE_IO=1          | don't change values here!
  24               	    OPT_TCDEV_EASTER_EGG=1              | don't change values here!
  25               	    OPT_REVEAL_SOL_TOWER=0              | don't change values here!
  26               	    OPT_REVEAL_BONUS_FLAG=0             | don't change values here!
  27               	    OPT_DISPLAY_AREA=0                  | don't change values here!
  28               	    OPT_SKIP_SPLASH=0                   | don't change values here!
  29               	    OPT_SKIP_ATTRACT=0                  | don't change values here!
  30               		.else
