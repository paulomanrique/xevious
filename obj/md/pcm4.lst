 172               	***************************************************************
 173               	*** OSD sound dispatch (NeoGeo priority/timer logic)
 174               	***************************************************************
 175               	
 176               	* d0 = sound ordinal
 177               	osd_sound_start:
 178 01a6 48E7 8080 	    movem.l d0/a0,-(a7)
68K GAS  src/megadrive/pcm4.68k 			page 8


 179 01aa 41F9 0000 	    lea     md_snd_playing,a0
 179      0000 
 180 01b0 4A28 0001 	    tst.b   (MAIN_THEME_SND,a0)                 | main theme playing?
 181 01b4 6700 0024 	    beq     0f
 182 01b8 0C00 000E 	    cmp.b   #SOLVALOU_SND,d0                    | only solvalou ticks its timer
 183 01bc 6600 0098 	    bne     9f
 184 01c0 5379 0000 	    subq.w  #1,(md_main_theme_cnt)
 184      0000 
 185 01c6 6600 008E 	    bne     9f
 186 01ca 4228 0001 	    clr.b   (MAIN_THEME_SND,a0)
 187 01ce 7001      	    moveq   #MAIN_THEME_SND,d0
 188 01d0 6100 FF78 	    bsr     md_pcm_stop
 189 01d4 700E      	    moveq   #SOLVALOU_SND,d0
 190 01d6 6000 006E 	    bra     snd_flag_and_play
 191 01da 4A28 0007 	0:  tst.b   (ANDOR_GENESIS_SND,a0)              | andor genesis playing?
