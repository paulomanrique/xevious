   9               	
  10               	    .global md_sound_init
  11               	    .global osd_sound_start
  12               	    .global osd_sound_stop
  13               	    .global osd_sound_mute
  14               	    .global osd_sound_unmute
  15               	
  16               	* Z80 driver RAM layout (offsets from Z80_RAM = 0xA00000)
  17               	    .equ    Z80_COMMAND,    0x0100              | byte: bit ch = start play
  18               	    .equ    Z80_STATUS,     0x0102              | byte0 play/ready, byte1 loop
  19               	    .equ    Z80_WAVADR,     0x0104              | + ch*4 : adr8-15, adr16-23, len8-15, len16-23
  20               	    .equ    Z80_IWAVADR,    0x0114              | + ch*4 : internal copy (stop writes here)
  21               	    .equ    Z80_WAVVOL,     0x0124              | + ch : volume 0-15
  22               	    .equ    Z80_NULLADR,    0x0128              | null sample adr bits8-23
  23               	    .equ    Z80_NULLLEN,    0x012A
  24               	
  25               	    .text
  26               	
  27               	***************************************************************
  28               	*** driver upload (Z80 already parked by startup: bus held)
  29               	***************************************************************
  30               	
  31               	md_sound_init:
68K GAS  src/megadrive/pcm4.68k 			page 5


  32 0000 48E7 80C0 	    movem.l d0/a0-a1,-(a7)
  33               	* copy the PCM4 driver to Z80 RAM 0x0000
  34 0004 41F9 0000 	    lea     pcm_driver,a0
  34      0000 
  35 000a 43F9 00A0 	    lea     (Z80_RAM),a1
  35      0000 
  36 0010 303C 0A6C 	    move.w  #pcm_driver_end-pcm_driver-1,d0
  37 0014 12D8      	1:  move.b  (a0)+,(a1)+
  38 0016 51C8 FFFC 	    dbf     d0,1b
  39               	* copy the 4KB volume table to Z80 RAM 0x1000
  40 001a 41F9 0000 	    lea     pcm_tab_vol,a0
  40      0000 
  41 0020 43F9 00A0 	    lea     (Z80_RAM+0x1000),a1
  41      1000 
  42 0026 303C 0FFF 	    move.w  #0x1000-1,d0
  43 002a 12D8      	2:  move.b  (a0)+,(a1)+
  44 002c 51C8 FFFC 	    dbf     d0,2b
  45               	* null-sample parameters (silence source, 256 bytes)
  46 0030 43F9 00A0 	    lea     (Z80_RAM),a1
  46      0000 
  47 0036 203C 0000 	    move.l  #pcm_smp_null,d0
  47      0000 
  48 003c E088      	    lsr.l   #8,d0
  49 003e 1340 0128 	    move.b  d0,(Z80_NULLADR,a1)
  50 0042 E088      	    lsr.l   #8,d0
  51 0044 1340 0129 	    move.b  d0,(Z80_NULLADR+1,a1)
  52 0048 137C 0001 	    move.b  #1,(Z80_NULLLEN,a1)                 | 256>>8
  52      012A 
  53 004e 137C 0000 	    move.b  #0,(Z80_NULLLEN+1,a1)
  53      012B 
  54 0054 137C 0000 	    move.b  #0,(Z80_COMMAND,a1)
  54      0100 
  55               	* clear volumes
  56 005a 41E9 0124 	    lea     (Z80_WAVVOL,a1),a0
  57 005e 10FC 0000 	    move.b  #0,(a0)+
  58 0062 10FC 0000 	    move.b  #0,(a0)+
  59 0066 10FC 0000 	    move.b  #0,(a0)+
  60 006a 10FC 0000 	    move.b  #0,(a0)+
  61               	* start the Z80: assert reset, release bus, release reset
  62 006e 33FC 0000 	    move.w  #0x000,(Z80_RESET)
  62      00A1 1200 
  63 0076 7028      	    moveq   #40,d0
  64 0078 51C8 FFFE 	3:  dbf     d0,3b
  65 007c 33FC 0000 	    move.w  #0x000,(Z80_BUSREQ)
  65      00A1 1100 
  66 0084 33FC 0100 	    move.w  #0x100,(Z80_RESET)
  66      00A1 1200 
  67 008c 4239 0000 	    clr.b   (md_snd_muted)
  67      0000 
  68 0092 4CDF 0301 	    movem.l (a7)+,d0/a0-a1
  69 0096 4E75      	    rts
  70               	
  71               	***************************************************************
  72               	*** Z80 bus helpers
  73               	***************************************************************
  74               	
  75               	md_z80_request:
68K GAS  src/megadrive/pcm4.68k 			page 6


  76 0098 33FC 0100 	    move.w  #0x100,(Z80_BUSREQ)
  76      00A1 1100 
  77 00a0 0839 0000 	1:  btst    #0,(Z80_BUSREQ)
  77      00A1 1100 
  78 00a8 66F6      	    bne.b   1b
  79 00aa 4E75      	    rts
  80               	
  81               	md_z80_release:
  82 00ac 33FC 0000 	    move.w  #0x000,(Z80_BUSREQ)
  82      00A1 1100 
  83 00b4 4E75      	    rts
  84               	
  85               	***************************************************************
  86               	*** PCM channel control
  87               	***************************************************************
  88               	
  89               	* d0 = sound ordinal -> start its sample on its channel
  90               	md_pcm_play:
  91 00b6 48E7 FEC0 	    movem.l d0-d6/a0-a1,-(a7)
  92 00ba 41F9 0000 	    lea     md_sound_table,a0
  92      0000 
  93 00c0 3C00      	    move.w  d0,d6
  94 00c2 E74E      	    lsl.w   #3,d6                               | 8 bytes/entry
  95 00c4 41F0 6000 	    lea     (a0,d6.w),a0
  96 00c8 2210      	    move.l  (a0),d1                             | sample address
  97 00ca 6700 0078 	    beq     9f                                  | unused ordinal -> ignore
  98 00ce 3428 0004 	    move.w  (4,a0),d2                           | length >> 8
  99 00d2 7600      	    moveq   #0,d3
 100 00d4 1628 0006 	    move.b  (6,a0),d3                           | channel (0-3)
 101 00d8 7800      	    moveq   #0,d4
 102 00da 1828 0007 	    move.b  (7,a0),d4                           | vol<<4 | loop
 103 00de 6100 FFB8 	    bsr     md_z80_request
 104 00e2 43F9 00A0 	    lea     (Z80_RAM),a1
 104      0000 
 105 00e8 3C03      	    move.w  d3,d6
 106 00ea E54E      	    lsl.w   #2,d6                               | ch*4
 107 00ec 0646 0104 	    addi.w  #Z80_WAVADR,d6
 108               	* WAVADR[ch] (8-bit indexed disp can't reach 0x104, so fold into the index)
 109 00f0 41F1 6000 	    lea     (a1,d6.w),a0
 110 00f4 2001      	    move.l  d1,d0
 111 00f6 E088      	    lsr.l   #8,d0
 112 00f8 1080      	    move.b  d0,(0,a0)                           | adr bits 8-15
 113 00fa E088      	    lsr.l   #8,d0
 114 00fc 1140 0001 	    move.b  d0,(1,a0)                           | adr bits 16-23
 115 0100 1142 0002 	    move.b  d2,(2,a0)                           | len bits 8-15
 116 0104 3002      	    move.w  d2,d0
 117 0106 E048      	    lsr.w   #8,d0
 118 0108 1140 0003 	    move.b  d0,(3,a0)                           | len bits 16-23
 119               	* volume (force 0 while muted)
 120 010c 3004      	    move.w  d4,d0
 121 010e E848      	    lsr.w   #4,d0                               | volume 0-15
 122 0110 4A39 0000 	    tst.b   (md_snd_muted)
 122      0000 
 123 0116 6702      	    beq.b   1f
 124 0118 7000      	    moveq   #0,d0
 125 011a 3C03      	1:  move.w  d3,d6
 126 011c 0646 0124 	    addi.w  #Z80_WAVVOL,d6
68K GAS  src/megadrive/pcm4.68k 			page 7


 127 0120 1380 6000 	    move.b  d0,(0,a1,d6.w)
 128               	* loop flag in STATUS byte 1
 129 0124 1029 0103 	    move.b  (Z80_STATUS+1,a1),d0
 130 0128 0780      	    bclr    d3,d0
 131 012a 0804 0000 	    btst    #0,d4                               | loop?
 132 012e 6702      	    beq.b   2f
 133 0130 07C0      	    bset    d3,d0
 134 0132 1340 0103 	2:  move.b  d0,(Z80_STATUS+1,a1)
 135               	* play command
 136 0136 1029 0100 	    move.b  (Z80_COMMAND,a1),d0
 137 013a 07C0      	    bset    d3,d0
 138 013c 1340 0100 	    move.b  d0,(Z80_COMMAND,a1)
 139 0140 6100 FF6A 	    bsr     md_z80_release
 140 0144 4CDF 037F 	9:  movem.l (a7)+,d0-d6/a0-a1
 141 0148 4E75      	    rts
 142               	
 143               	* d0 = sound ordinal -> stop its channel
 144               	md_pcm_stop:
 145 014a 48E7 F0C0 	    movem.l d0-d3/a0-a1,-(a7)
 146 014e 41F9 0000 	    lea     md_sound_table,a0
 146      0000 
 147 0154 3200      	    move.w  d0,d1
 148 0156 E749      	    lsl.w   #3,d1
 149 0158 1630 1006 	    move.b  (6,a0,d1.w),d3                      | channel
 150 015c 6100 FF3A 	    bsr     md_z80_request
 151 0160 43F9 00A0 	    lea     (Z80_RAM),a1
 151      0000 
 152 0166 3203      	    move.w  d3,d1
 153 0168 E549      	    lsl.w   #2,d1                               | ch*4
 154 016a 0641 0114 	    addi.w  #Z80_IWAVADR,d1
 155               	* point internal sample at the null sample
 156 016e 41F1 1000 	    lea     (a1,d1.w),a0
 157 0172 10A9 0128 	    move.b  (Z80_NULLADR,a1),(0,a0)
 158 0176 1169 0129 	    move.b  (Z80_NULLADR+1,a1),(1,a0)
 158      0001 
 159 017c 1169 012A 	    move.b  (Z80_NULLLEN,a1),(2,a0)
 159      0002 
 160 0182 1169 012B 	    move.b  (Z80_NULLLEN+1,a1),(3,a0)
 160      0003 
 161               	* clear play + loop status
 162 0188 1029 0102 	    move.b  (Z80_STATUS,a1),d0
 163 018c 0780      	    bclr    d3,d0
 164 018e 1340 0102 	    move.b  d0,(Z80_STATUS,a1)
 165 0192 1029 0103 	    move.b  (Z80_STATUS+1,a1),d0
 166 0196 0780      	    bclr    d3,d0
 167 0198 1340 0103 	    move.b  d0,(Z80_STATUS+1,a1)
 168 019c 6100 FF0E 	    bsr     md_z80_release
 169 01a0 4CDF 030F 	    movem.l (a7)+,d0-d3/a0-a1
 170 01a4 4E75      	    rts
