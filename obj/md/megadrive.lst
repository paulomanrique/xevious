  37               	
  38               	* display geometry
  39               	* playfield: 224px wide at nametable columns 6..33 (screen x 48..271)
  40               	* arcade fg rows 4..39 -> plane A rows 0..35; hidden/unused rows -> plane row 44
  41               	* arcade bg rows 0..63 -> plane B rows 0..63 (vscroll selects window)
  42               	    .equ    MD_LEFT_COL,    6
  43               	    .equ    FG_DUMP_ROW,    44
  44               	* display window: arcade screen rows (srow 0-35; fg row = srow+4)
  45               	*  game:  srows 4..31  (top HUD srows 0-1 and bottom srow 35 live on the panel)
  46               	*  title: srows 7..34  (logos, hiscore table, copyright lines)
  47               	* plane A vscroll = (window top srow) * 8
  48               	* bg vscroll = (FGV - 56 - scroll) & 511; from arcade row relation
  49               	* bg_row = fg_row - 11 - scroll/8 (scroll moves terrain DOWN the screen)
  50               	    .equ    FGV_GAME,       32                  | plane A vscroll per mode
  51               	    .equ    FGV_TITLE,      56
  52               	    .equ    VBIAS_GAME,     (FGV_GAME-56)&511
  53               	    .equ    VBIAS_TITLE,    (FGV_TITLE-56)&511
  54               	
  55               	* HUD panel (window plane, screen columns 34-39, 6 cells wide)
  56               	    .equ    PANEL_COL,      34
  57               	    .equ    PANEL_W,        6
  58               	    .equ    PANEL_ROWS,     28
  59               	    .equ    SOLID_SLOT,     GFX_FG_CACHE_TILES-1 | reserved opaque-black tile
  60               	
  61               	* fg cache overflow: title-type screens (logo, hiscore table) need more than
  62               	* 128 live (char,colour) combos; borrow the tail of the sprite pool while in
  63               	* title mode (sprites are idle there), purged when gameplay starts
  64               	    .equ    FG_OVF_SLOTS,   96
  65               	    .equ    FG_TOTAL_SLOTS, GFX_FG_CACHE_TILES+FG_OVF_SLOTS
  66               	    .equ    FG_OVF_TILE,    GFX_POOL_BASE_TILE+GFX_POOL_TILES-FG_OVF_SLOTS
  67               	* panel glyphs: pre-rendered opaque tiles, independent of the fg cache;
  68               	* placed just below the overflow region at the pool tail
  69               	    .equ    PANEL_GLYPHS,   19
  70               	    .equ    PANEL_TILE,     FG_OVF_TILE-PANEL_GLYPHS
  71               	* glyph ids: 0-9 digits, 10..16 = U,P,H,I,A,C,R, 17 ship icon, 18 solid black
  72               	    .equ    PG_U,           10
  73               	    .equ    PG_P,           11
  74               	    .equ    PG_H,           12
  75               	    .equ    PG_I,           13
  76               	    .equ    PG_A,           14
  77               	    .equ    PG_C,           15
  78               	    .equ    PG_R,           16
  79               	    .equ    PG_SHIP,        17
  80               	    .equ    PG_SOLID,       18
  81               	* panel text colours (arcade fg colour codes 0-63)
  82               	    .equ    PCOL_TEXT,      61                  | white
  83               	    .equ    PCOL_LABEL,     38                  | red
  84               	    .equ    PCOL_ICON,      42                  | ship icon colour (core uses 0x2A)
  85               	* chars: digits 0x00-0x09, uppercase 'A'=0x0A.., space 0x24, ship icon 0x25
  86               	    .equ    CH_SPACE,       0x24
  87               	    .equ    CH_SHIP,        0x25
