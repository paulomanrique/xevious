  89               	* debug probe: paint the backdrop to trace how far execution gets
  90               	    .macro  PROBE colour
  91               	    .ifdef DEBUG
  92               	    move.l  #0xC0000000,(VDP_CTRL)
  93               	    move.w  #\colour,(VDP_DATA)
  94               	    .endif
  95               	    .endm
