 103               	md_main:
 104 0000 6100 0008 	    bsr     md_platform_init
 105               	    .ifdef DIAG_FGTEST
 106               	* isolated fg pipeline test: draw a grid of chars without the core
 107               	* row r (4..19), col c (0..27): char = r*2, attr = colour pattern
 108               	    moveq   #0,d6                               | row index 0..15
 109               	fgtest_row:
 110               	    moveq   #0,d7                               | col 0..27
 111               	fgtest_col:
 112               	    move.w  d6,d0
 113               	    addq.w  #4,d0                               | fg row 4..19
 114               	    move.w  d7,d1
 115               	    lsl.w   #6,d1
 116               	    add.w   d1,d0                               | offset = col*64+row
 117               	    * attr: colour bits[3:0] in attr[5:2] -> colour = row (1..15)
 118               	    move.w  d6,d1
 119               	    addq.w  #1,d1
 120               	    andi.w  #0x0F,d1
 121               	    lsl.w   #2,d1                               | attr[5:2] = colour[3:0]
 122               	    jsr     osd_w_fg_colorram
 123               	    * char = col*2 (0,2,4..54)
 124               	    move.w  d7,d1
 125               	    add.w   d1,d1
 126               	    jsr     osd_w_fg_videoram
 127               	    addq.w  #1,d7
 128               	    cmpi.w  #28,d7
 129               	    blt.b   fgtest_col
 130               	    addq.w  #1,d6
 131               	    cmpi.w  #16,d6
 132               	    blt.b   fgtest_row
 133               	fgtest_spin:
 134               	    bra.b   fgtest_spin
 135               	    .endif
 136 0004 4EF9 0000 	    jmp     xevious_reset
 136      0000 
