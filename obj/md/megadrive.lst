  36               	
  37               	* display geometry
  38               	* playfield: 224px wide at nametable columns 6..33 (screen x 48..271)
  39               	* arcade fg rows 4..39 -> plane A rows 0..35; hidden/unused rows -> plane row 44
  40               	* arcade bg rows 0..63 -> plane B rows 0..63 (vscroll selects window)
  41               	    .equ    MD_LEFT_COL,    6
  42               	    .equ    FG_DUMP_ROW,    44
  43               	* display window: arcade screen rows (srow 0-35; fg row = srow+4)
  44               	*  game:  srows 4..31  (top HUD srows 0-1 and bottom srow 35 live on the panel)
68K GAS  src/megadrive/megadrive.68k 			page 7


  45               	*  title: srows 7..34  (logos, hiscore table, copyright lines)
  46               	* plane A vscroll = (window top srow) * 8
  47               	* bg vscroll = (FGV - 56 - scroll) & 511; from arcade row relation
  48               	* bg_row = fg_row - 11 - scroll/8 (scroll moves terrain DOWN the screen)
  49               	    .equ    FGV_GAME,       32                  | plane A vscroll per mode
  50               	    .equ    FGV_TITLE,      56
  51               	    .equ    VBIAS_GAME,     (FGV_GAME-56)&511
  52               	    .equ    VBIAS_TITLE,    (FGV_TITLE-56)&511
  53               	
  54               	* HUD panel (window plane, screen columns 34-39, 6 cells wide)
  55               	    .equ    PANEL_COL,      34
  56               	    .equ    PANEL_W,        6
  57               	    .equ    PANEL_ROWS,     28
  58               	    .equ    SOLID_SLOT,     GFX_FG_CACHE_TILES-1 | reserved opaque-black tile
  59               	
  60               	* fg cache overflow: title-type screens (logo, hiscore table) need more than
  61               	* 128 live (char,colour) combos; borrow the tail of the sprite pool while in
  62               	* title mode (sprites are idle there), purged when gameplay starts
  63               	    .equ    FG_OVF_SLOTS,   96
  64               	    .equ    FG_TOTAL_SLOTS, GFX_FG_CACHE_TILES+FG_OVF_SLOTS
  65               	    .equ    FG_OVF_TILE,    GFX_POOL_BASE_TILE+GFX_POOL_TILES-FG_OVF_SLOTS
  66               	* panel glyphs: pre-rendered opaque tiles, independent of the fg cache;
  67               	* placed just below the overflow region at the pool tail
  68               	    .equ    PANEL_GLYPHS,   19
  69               	    .equ    PANEL_TILE,     FG_OVF_TILE-PANEL_GLYPHS
  70               	* glyph ids: 0-9 digits, 10..16 = U,P,H,I,A,C,R, 17 ship icon, 18 solid black
  71               	    .equ    PG_U,           10
  72               	    .equ    PG_P,           11
  73               	    .equ    PG_H,           12
  74               	    .equ    PG_I,           13
  75               	    .equ    PG_A,           14
  76               	    .equ    PG_C,           15
  77               	    .equ    PG_R,           16
  78               	    .equ    PG_SHIP,        17
  79               	    .equ    PG_SOLID,       18
  80               	* panel text colours (arcade fg colour codes 0-63)
  81               	    .equ    PCOL_TEXT,      61                  | white
  82               	    .equ    PCOL_LABEL,     38                  | red
  83               	    .equ    PCOL_ICON,      42                  | ship icon colour (core uses 0x2A)
  84               	* chars: digits 0x00-0x09, uppercase 'A'=0x0A.., space 0x24, ship icon 0x25
  85               	    .equ    CH_SPACE,       0x24
  86               	    .equ    CH_SHIP,        0x25
  87               	
  88               	* debug probe: paint the backdrop to trace how far execution gets
  89               	    .macro  PROBE colour
  90               	    .ifdef DEBUG
  91               	    move.l  #0xC0000000,(VDP_CTRL)
  92               	    move.w  #\colour,(VDP_DATA)
  93               	    .endif
  94               	    .endm
  95               	
  96               	    .text
