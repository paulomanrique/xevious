 522               	*** HUD panel (window plane, right side)
 523               	***************************************************************
 524               	
 525               	* panel layout (rows 0..27 of 6 cells):
 526               	*  0 "1UP"  1 p1 score   3 "HI"  4 hi score   6 "2UP"  7 p2 score
 527               	*  20 "A" + area   24 "CR" + credits   26 lives icons
 528               	* The panel uses its own pre-rendered opaque glyph tiles (PANEL_TILE..)
 529               	* so it never competes with the in-field fg cache.
 530               	
 531               	* glyph build table: char code, colour code
 532               	panel_glyph_tbl:
 533 0414 003D 013D 	    .byte   0x00,PCOL_TEXT, 0x01,PCOL_TEXT, 0x02,PCOL_TEXT, 0x03,PCOL_TEXT
 533      023D 033D 
 534 041c 043D 053D 	    .byte   0x04,PCOL_TEXT, 0x05,PCOL_TEXT, 0x06,PCOL_TEXT, 0x07,PCOL_TEXT
 534      063D 073D 
 535 0424 083D 093D 	    .byte   0x08,PCOL_TEXT, 0x09,PCOL_TEXT
 536 0428 1E26 1926 	    .byte   0x1E,PCOL_LABEL, 0x19,PCOL_LABEL, 0x11,PCOL_LABEL, 0x12,PCOL_LABEL
 536      1126 1226 
 537 0430 0A26 0C26 	    .byte   0x0A,PCOL_LABEL, 0x0C,PCOL_LABEL, 0x1B,PCOL_LABEL
 537      1B26 
 538 0436 252A      	    .byte   CH_SHIP,PCOL_ICON
 539 0438 243D      	    .byte   CH_SPACE,PCOL_TEXT                  | solid black
 540               	    .align 2
