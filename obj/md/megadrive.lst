68K GAS  src/megadrive/megadrive.68k 			page 37


 1547               	***************************************************************
 1548               	* SRAM layout (consecutive odd bytes from 0x200001):
 1549               	*   [0..3] signature 'XEVS'  [4] checksum  [5..5+0x4F] the 0x50-byte table
 1550               	    .equ    HS_TABLE_LEN,   0x50
 1551               	
 1552               	* a0 = dest high-score table, a1 = dest current-high-score (3 BCD)
 1553               	* reads into a scratch buffer and validates before touching the core table,
 1554               	* so a corrupt/blank SRAM leaves the core's just-initialised defaults intact
 1555               	osd_read_high_scores:
 1556 0db4 48E7 F1F0 	    movem.l d0-d3/d7/a0-a3,-(a7)
 1557 0db8 45F9 0020 	    lea     (SRAM_BASE),a2                      | 0x200001
 1557      0001 
 1558               	* check signature
 1559 0dbe 47FA 00AC 	    lea     hs_signature(pc),a3
 1560 0dc2 7E03      	    moveq   #4-1,d7
 1561 0dc4 1012      	1:  move.b  (a2),d0
 1562 0dc6 D5FC 0000 	    adda.l  #2,a2
 1562      0002 
 1563 0dcc B01B      	    cmp.b   (a3)+,d0
 1564 0dce 6600 0054 	    bne     9f                                  | bad signature -> keep defaults
