 102               	md_main:
 103 0000 6100 0008 	    bsr     md_platform_init
 104               	    .ifdef DIAG_FGTEST
 105               	* isolated fg pipeline test: draw a grid of chars without the core
 106               	* row r (4..19), col c (0..27): char = r*2, attr = colour pattern
 107               	    moveq   #0,d6                               | row index 0..15
 108               	fgtest_row:
 109               	    moveq   #0,d7                               | col 0..27
 110               	fgtest_col:
 111               	    move.w  d6,d0
 112               	    addq.w  #4,d0                               | fg row 4..19
 113               	    move.w  d7,d1
 114               	    lsl.w   #6,d1
 115               	    add.w   d1,d0                               | offset = col*64+row
 116               	    * attr: colour bits[3:0] in attr[5:2] -> colour = row (1..15)
 117               	    move.w  d6,d1
 118               	    addq.w  #1,d1
 119               	    andi.w  #0x0F,d1
 120               	    lsl.w   #2,d1                               | attr[5:2] = colour[3:0]
 121               	    jsr     osd_w_fg_colorram
 122               	    * char = col*2 (0,2,4..54)
 123               	    move.w  d7,d1
 124               	    add.w   d1,d1
 125               	    jsr     osd_w_fg_videoram
 126               	    addq.w  #1,d7
 127               	    cmpi.w  #28,d7
 128               	    blt.b   fgtest_col
 129               	    addq.w  #1,d6
 130               	    cmpi.w  #16,d6
 131               	    blt.b   fgtest_row
 132               	fgtest_spin:
 133               	    bra.b   fgtest_spin
 134               	    .endif
