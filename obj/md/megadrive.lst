 524               	***************************************************************
 525               	*** HUD panel (window plane, right side)
 526               	***************************************************************
 527               	
 528               	* panel layout (rows 0..27 of 6 cells):
 529               	*  0 "1UP"  1 p1 score   3 "HI"  4 hi score   6 "2UP"  7 p2 score
 530               	*  20 "A" + area   24 "CR" + credits   26 lives icons
 531               	* The panel uses its own pre-rendered opaque glyph tiles (PANEL_TILE..)
 532               	* so it never competes with the in-field fg cache.
 533               	
 534               	* glyph build table: char code, colour code
 535               	panel_glyph_tbl:
 536 0416 003D 013D 	    .byte   0x00,PCOL_TEXT, 0x01,PCOL_TEXT, 0x02,PCOL_TEXT, 0x03,PCOL_TEXT
 536      023D 033D 
 537 041e 043D 053D 	    .byte   0x04,PCOL_TEXT, 0x05,PCOL_TEXT, 0x06,PCOL_TEXT, 0x07,PCOL_TEXT
 537      063D 073D 
 538 0426 083D 093D 	    .byte   0x08,PCOL_TEXT, 0x09,PCOL_TEXT
 539 042a 1E26 1926 	    .byte   0x1E,PCOL_LABEL, 0x19,PCOL_LABEL, 0x11,PCOL_LABEL, 0x12,PCOL_LABEL
 539      1126 1226 
 540 0432 0A26 0C26 	    .byte   0x0A,PCOL_LABEL, 0x0C,PCOL_LABEL, 0x1B,PCOL_LABEL
 540      1B26 
 541 0438 252A      	    .byte   CH_SHIP,PCOL_ICON
 542 043a 243D      	    .byte   CH_SPACE,PCOL_TEXT                  | solid black
