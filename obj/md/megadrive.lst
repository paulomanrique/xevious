 528               	***************************************************************
 529               	*** HUD panel (window plane, right side)
 530               	***************************************************************
 531               	
 532               	* panel layout (rows 0..27 of 6 cells):
 533               	*  0 "1UP"  1 p1 score   3 "HI"  4 hi score   6 "2UP"  7 p2 score
 534               	*  20 "A" + area   24 "CR" + credits   26 lives icons
 535               	* The panel uses its own pre-rendered opaque glyph tiles (PANEL_TILE..)
 536               	* so it never competes with the in-field fg cache.
 537               	
 538               	* glyph build table: char code, colour code
 539               	panel_glyph_tbl:
 540 041a 003D 013D 	    .byte   0x00,PCOL_TEXT, 0x01,PCOL_TEXT, 0x02,PCOL_TEXT, 0x03,PCOL_TEXT
 540      023D 033D 
 541 0422 043D 053D 	    .byte   0x04,PCOL_TEXT, 0x05,PCOL_TEXT, 0x06,PCOL_TEXT, 0x07,PCOL_TEXT
 541      063D 073D 
 542 042a 083D 093D 	    .byte   0x08,PCOL_TEXT, 0x09,PCOL_TEXT
 543 042e 1E26 1926 	    .byte   0x1E,PCOL_LABEL, 0x19,PCOL_LABEL, 0x11,PCOL_LABEL, 0x12,PCOL_LABEL
 543      1126 1226 
 544 0436 0A26 0C26 	    .byte   0x0A,PCOL_LABEL, 0x0C,PCOL_LABEL, 0x1B,PCOL_LABEL
 544      1B26 
 545 043c 252A      	    .byte   CH_SHIP,PCOL_ICON
 546 043e 243D      	    .byte   CH_SPACE,PCOL_TEXT                  | solid black
 547               	    .align 2
