   1               	*
   2               	* Mega Drive hardware definitions for Xevious port
   3               	*
   4               	
   5               	* 68K memory map
   6               	    .equ    ROM_BASE,       0x000000
   7               	    .equ    SRAM_BASE,      0x200001            | odd bytes
   8               	    .equ    SRAM_END,       0x2003FF
   9               	    .equ    Z80_RAM,        0xA00000
  10               	    .equ    Z80_BUSREQ,     0xA11100
  11               	    .equ    Z80_RESET,      0xA11200
  12               	    .equ    IO_VERSION,     0xA10001
  13               	    .equ    IO_DATA1,       0xA10003
  14               	    .equ    IO_DATA2,       0xA10005
  15               	    .equ    IO_CTRL1,       0xA10009
  16               	    .equ    IO_CTRL2,       0xA1000B
  17               	    .equ    TMSS_REG,       0xA14000
  18               	    .equ    SRAM_CTRL,      0xA130F1
  19               	    .equ    RAM_BASE,       0xFF0000
  20               	
  21               	* VDP ports
  22               	    .equ    VDP_DATA,       0xC00000
  23               	    .equ    VDP_CTRL,       0xC00004
  24               	    .equ    VDP_HV,         0xC00008
  25               	    .equ    PSG_PORT,       0xC00011
  26               	
  27               	* VRAM layout
  28               	* tile patterns: 0x0000-0x9FFF (tile 0 = blank)
  29               	*   bg game patterns   from 0x0020 (generated, see graphics_md.68k)
  30               	*   sprite pool        after bg    (generated bound; panel glyphs + fg
  31               	*                      overflow live at the pool tail)
  32               	* fg dynamic cache: 96 tiles at 0xB000-0xBBFF (tiles 1408-1503)
  33               	    .equ    VRAM_WINDOW_NT, 0xA000              | 64x32 window nametable (4KB)
  34               	    .equ    VRAM_SAT,       0xBC00              | sprite attribute table (640B)
  35               	    .equ    VRAM_HSCROLL,   0xBF00              | hscroll table
  36               	    .equ    VRAM_PLANE_A,   0xC000              | 64x64 nametable (8KB)
  37               	    .equ    VRAM_PLANE_B,   0xE000              | 64x64 nametable (8KB)
  38               	
  39               	* VDP register values
  40               	* NOTE: '|' is the comment char in MIT syntax: use '+' in expressions!
  41               	    .equ    VDPR00, 0x8004                      | mode 1: no hint, normal ops
  42               	    .equ    VDPR01_OFF, 0x8134                  | mode 2: display off, vint, dma, V28, mode5
  43               	    .equ    VDPR01_ON,  0x8174                  | mode 2: display on
  44               	    .equ    VDPR02, 0x8200+(VRAM_PLANE_A>>10)   | plane A nametable
  45               	    .equ    VDPR03, 0x8300+(VRAM_WINDOW_NT>>10) | window nametable
  46               	    .equ    VDPR04, 0x8400+(VRAM_PLANE_B>>13)   | plane B nametable
  47               	    .equ    VDPR05, 0x8500+(VRAM_SAT>>9)        | sprite attribute table
  48               	    .equ    VDPR06, 0x8600
  49               	    .equ    VDPR07, 0x8700                      | backdrop colour = pal0 idx0
  50               	    .equ    VDPR08, 0x8800
  51               	    .equ    VDPR09, 0x8900
  52               	    .equ    VDPR10, 0x8AFF                      | hint counter
68K GAS  src/megadrive/megadrive.68k 			page 2


  53               	    .equ    VDPR11, 0x8B00                      | full-screen scroll
  54               	    .equ    VDPR12, 0x8C81                      | H40, no shadow/hilite, no interlace
  55               	    .equ    VDPR13, 0x8D00+(VRAM_HSCROLL>>10)   | hscroll table
  56               	    .equ    VDPR14, 0x8E00
  57               	    .equ    VDPR15, 0x8F02                      | autoincrement 2
  58               	    .equ    VDPR16, 0x9011                      | plane size 64x64
  59               	    .equ    VDPR17, 0x9191                      | window: right side, x>=272 (17*16)
  60               	    .equ    VDPR18, 0x9200                      | window Y: full height
  61               	
  62               	* VDP command address macros (control port longword formats)
  63               	* vram write:  0x40000000 + (a&0x3FFF)<<16 + (a&0xC000)>>14
  64               	* cram write:  0xC0000000 + ...
  65               	* vsram write: 0x40000010 + ...
  66               	
  67               	    .macro  VDP_W_VRAM   addr
  68               	    move.l  #0x40000000+((\addr&0x3FFF)<<16)+((\addr)>>14),(VDP_CTRL)
  69               	    .endm
  70               	
  71               	    .macro  VDP_W_CRAM   addr
  72               	    move.l  #0xC0000000+((\addr&0x3FFF)<<16)+((\addr)>>14),(VDP_CTRL)
  73               	    .endm
  74               	
  75               	    .macro  VDP_W_VSRAM  addr
  76               	    move.l  #0x40000010+((\addr&0x3FFF)<<16)+((\addr)>>14),(VDP_CTRL)
  77               	    .endm
