  77 00c4 13FC 0040 	    move.b  #0x40,(IO_DATA1)
  77      00A1 0003 
  78 00cc 13FC 0040 	    move.b  #0x40,(IO_DATA2)
  78      00A1 0005 
  79               	
  80 00d4 4EF9 0000 	    jmp     md_main
  80      0000 
