   1               	*
   2               	* Mega Drive startup: TMSS, VDP/Z80/PSG init, RAM clear
   3               	*
   4               	
   5               	    .include "vdpregs.inc"
   1               	*
   2               	* Mega Drive hardware definitions for Xevious port
   3               	*
   4               	
   5               	* 68K memory map
   6               	    .equ    ROM_BASE,       0x000000
   7               	    .equ    SRAM_BASE,      0x200001            | odd bytes
   8               	    .equ    SRAM_END,       0x2003FF
   9               	    .equ    Z80_RAM,        0xA00000
  10               	    .equ    Z80_BUSREQ,     0xA11100
  11               	    .equ    Z80_RESET,      0xA11200
  12               	    .equ    IO_VERSION,     0xA10001
  13               	    .equ    IO_DATA1,       0xA10003
  14               	    .equ    IO_DATA2,       0xA10005
  15               	    .equ    IO_CTRL1,       0xA10009
  16               	    .equ    IO_CTRL2,       0xA1000B
  17               	    .equ    TMSS_REG,       0xA14000
  18               	    .equ    SRAM_CTRL,      0xA130F1
  19               	    .equ    RAM_BASE,       0xFF0000
  20               	
  21               	* VDP ports
  22               	    .equ    VDP_DATA,       0xC00000
  23               	    .equ    VDP_CTRL,       0xC00004
  24               	    .equ    VDP_HV,         0xC00008
  25               	    .equ    PSG_PORT,       0xC00011
  26               	
  27               	* VRAM layout
  28               	* tile patterns: 0x0000-0xAFFF (tile 0 = blank)
  29               	*   bg game patterns   from 0x0020 (generated, see graphics_md.68k)
  30               	*   sprite pool        after bg    (generated bound)
  31               	*   fg dynamic cache   below window NT
  32               	    .equ    VRAM_WINDOW_NT, 0xB000              | 64x32 window nametable (4KB)
  33               	    .equ    VRAM_SAT,       0xBC00              | sprite attribute table (640B)
  34               	    .equ    VRAM_HSCROLL,   0xBF00              | hscroll table
  35               	    .equ    VRAM_PLANE_A,   0xC000              | 64x64 nametable (8KB)
  36               	    .equ    VRAM_PLANE_B,   0xE000              | 64x64 nametable (8KB)
  37               	
  38               	* VDP register values
  39               	* NOTE: '|' is the comment char in MIT syntax: use '+' in expressions!
  40               	    .equ    VDPR00, 0x8004                      | mode 1: no hint, normal ops
  41               	    .equ    VDPR01_OFF, 0x8134                  | mode 2: display off, vint, dma, V28, mode5
  42               	    .equ    VDPR01_ON,  0x8174                  | mode 2: display on
  43               	    .equ    VDPR02, 0x8200+(VRAM_PLANE_A>>10)   | plane A nametable
  44               	    .equ    VDPR03, 0x8300+(VRAM_WINDOW_NT>>10) | window nametable
  45               	    .equ    VDPR04, 0x8400+(VRAM_PLANE_B>>13)   | plane B nametable
  46               	    .equ    VDPR05, 0x8500+(VRAM_SAT>>9)        | sprite attribute table
  47               	    .equ    VDPR06, 0x8600
  48               	    .equ    VDPR07, 0x8700                      | backdrop colour = pal0 idx0
  49               	    .equ    VDPR08, 0x8800
  50               	    .equ    VDPR09, 0x8900
  51               	    .equ    VDPR10, 0x8AFF                      | hint counter
  52               	    .equ    VDPR11, 0x8B00                      | full-screen scroll
68K GAS  src/megadrive/startup.68k 			page 2


  53               	    .equ    VDPR12, 0x8C81                      | H40, no shadow/hilite, no interlace
  54               	    .equ    VDPR13, 0x8D00+(VRAM_HSCROLL>>10)   | hscroll table
  55               	    .equ    VDPR14, 0x8E00
  56               	    .equ    VDPR15, 0x8F02                      | autoincrement 2
  57               	    .equ    VDPR16, 0x9011                      | plane size 64x64
  58               	    .equ    VDPR17, 0x9191                      | window: right side, x>=272 (17*16)
  59               	    .equ    VDPR18, 0x9200                      | window Y: full height
  60               	
  61               	* VDP command address macros (control port longword formats)
  62               	* vram write:  0x40000000 + (a&0x3FFF)<<16 + (a&0xC000)>>14
  63               	* cram write:  0xC0000000 + ...
  64               	* vsram write: 0x40000010 + ...
  65               	
  66               	    .macro  VDP_W_VRAM   addr
  67               	    move.l  #0x40000000+((\addr&0x3FFF)<<16)+((\addr)>>14),(VDP_CTRL)
  68               	    .endm
  69               	
  70               	    .macro  VDP_W_CRAM   addr
  71               	    move.l  #0xC0000000+((\addr&0x3FFF)<<16)+((\addr)>>14),(VDP_CTRL)
  72               	    .endm
  73               	
  74               	    .macro  VDP_W_VSRAM  addr
  75               	    move.l  #0x40000010+((\addr&0x3FFF)<<16)+((\addr)>>14),(VDP_CTRL)
  76               	    .endm
   6               	
   7               	    .global md_error
   8               	    .global md_ext_irq
   9               	    .global md_hblank
  10               	    .global _start
  11               	
  12               	    .text
  13               	
  14               	_start:
  15 0000 46FC 2700 	    move    #0x2700,sr                          | interrupts off
  16               	
  17               	* TMSS: write 'SEGA' on model 1 VA4+ hardware
  18 0004 1039 00A1 	    move.b  (IO_VERSION),d0
  18      0001 
  19 000a 0200 000F 	    andi.b  #0x0F,d0
  20 000e 670A      	    beq.b   1f
  21 0010 23FC 5345 	    move.l  #0x53454741,(TMSS_REG)              | 'SEGA'
  21      4741 00A1 
  21      4000 
  22               	1:
  23               	
  24               	* stop the Z80: request bus and release reset (bus is only granted with
  25               	* reset deasserted); keep BUSREQ held so the Z80 stays parked until the
  26               	* sound driver is uploaded
  27 001a 33FC 0100 	    move.w  #0x100,(Z80_BUSREQ)                 | request bus
  27      00A1 1100 
  28 0022 33FC 0100 	    move.w  #0x100,(Z80_RESET)                  | deassert reset
  28      00A1 1200 
  29 002a 0839 0000 	2:  btst    #0,(Z80_BUSREQ)
  29      00A1 1100 
  30 0032 66F6      	    bne.b   2b
  31               	
  32               	* silence PSG
68K GAS  src/megadrive/startup.68k 			page 3


  33 0034 41F9 00C0 	    lea     (PSG_PORT),a0
  33      0011 
  34 003a 10BC 009F 	    move.b  #0x9F,(a0)
  35 003e 10BC 00BF 	    move.b  #0xBF,(a0)
  36 0042 10BC 00DF 	    move.b  #0xDF,(a0)
  37 0046 10BC 00FF 	    move.b  #0xFF,(a0)
  38               	
  39               	* init VDP registers (display off)
  40 004a 41F9 00C0 	    lea     (VDP_CTRL),a0
  40      0004 
  41 0050 3010      	    move.w  (a0),d0                             | clear latched state
  42 0052 43FA 0086 	    lea     vdp_init_regs(pc),a1
  43 0056 7E12      	    moveq   #(vdp_init_regs_end-vdp_init_regs)/2-1,d7
  44 0058 3099      	3:  move.w  (a1)+,(a0)
  45 005a 51CF FFFC 	    dbf     d7,3b
  46               	
  47               	* clear VRAM (64KB) via data port
  48 005e 23FC 4000 	    VDP_W_VRAM 0
  48      0000 00C0 
  48      0004 
  49 0068 43F9 00C0 	    lea     (VDP_DATA),a1
  49      0000 
  50 006e 3E3C 7FFF 	    move.w  #0x8000-1,d7
  51 0072 7000      	    moveq   #0,d0
  52 0074 2280      	4:  move.l  d0,(a1)
  53 0076 51CF FFFC 	    dbf     d7,4b
  54               	
  55               	* clear CRAM (64 entries)
  56 007a 23FC C000 	    VDP_W_CRAM 0
  56      0000 00C0 
  56      0004 
  57 0084 7E1F      	    moveq   #32-1,d7
  58 0086 2280      	5:  move.l  d0,(a1)
  59 0088 51CF FFFC 	    dbf     d7,5b
  60               	
  61               	* clear VSRAM (40 entries)
  62 008c 23FC 4000 	    VDP_W_VSRAM 0
  62      0010 00C0 
  62      0004 
  63 0096 7E13      	    moveq   #20-1,d7
  64 0098 2280      	6:  move.l  d0,(a1)
  65 009a 51CF FFFC 	    dbf     d7,6b
  66               	
  67               	* clear work RAM (64KB) except nothing is live yet; SP reloaded after
  68 009e 43F9 00FF 	    lea     (RAM_BASE).l,a1
  68      0000 
  69 00a4 3E3C 3FFF 	    move.w  #0x4000-1,d7
  70 00a8 22C0      	7:  move.l  d0,(a1)+
  71 00aa 51CF FFFC 	    dbf     d7,7b
  72 00ae 4FF9 00FF 	    lea     (0x00FFFE00).l,sp
  72      FE00 
  73               	
  74               	* set up controller ports: TH output, rest input
  75 00b4 13FC 0040 	    move.b  #0x40,(IO_CTRL1)
  75      00A1 0009 
  76 00bc 13FC 0040 	    move.b  #0x40,(IO_CTRL2)
  76      00A1 000B 
