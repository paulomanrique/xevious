 478               	    
 479               	* handles Domogram (dome that follows paths)
 480               	* byte2 = type
 481               	* byte3 = offset
 482               	* byte4 = sprite Y
 483               	* byte5 = num 2-byte entries to follow
 484               	* byte6 = vector length
 485               	* byte7 = index into domogram vector table (dY,dX pairs)
 486               	* byteN...
 487               	*
 488               	* @$7F<byte3> = <byte2> (type)
 489               	* @$7B<byte3> = <byte4> sprite Y[2:0] x32
 490               	* @$7B<byte3+1> = <byte4> sprite Y[7:3] /8
 491               	* @$7D<byte3+1> = <byte5> num 2-byte entries to follow
 492               	* @$9380<n*64> = <byte5>*2 bytes copied from <byte6> onwards
 493               	
 494               	sub_2_fn_15__domogram: | $05E1
 495 06a6 7000      	    moveq     #0,d0
 496 06a8 1010      	    move.b    (a0),d0                           | byte3=object offset (Z80)
 497               	    *** this will change if _OBJSIZE changes
 498 06aa E948      	    lsl.w     #4,d0                             | object offset (68K)
 499 06ac 4BF9 0000 	    lea       obj_tbl,a5
 499      0000 
 500 06b2 4BF5 0000 	    lea       (a5,d0.w),a5                      | set object base
 501 06b6 1B68 FFFF 	    move.b    (-1,a0),(_TYPE,a5)
 501      001E 
 502 06bc 7000      	    moveq     #0,d0
 503 06be 1028 0001 	    move.b    (1,a0),d0                         | byte4=spriteY
 504 06c2 EB48      	    lsl.w     #5,d0                             | x32
 505 06c4 3B40 000E 	    move.w    d0,(_Y,a5)
 506 06c8 7000      	    moveq     #0,d0
 507 06ca 1028 0002 	    move.b    (2,a0),d0                         | byte5=num entries
 508 06ce D0FC 0003 	    adda.w    #3,a0                             | ptr domogrm data
 509 06d2 2248      	    move.l    a0,a1                             | copy
 510 06d4 1B40 0019 	    move.b    d0,(_NVEC,a5)                     | number of domogram vectors
 511 06d8 D040      	    add.w     d0,d0                             | bytes to skip
 512 06da D0C0      	    adda.w    d0,a0
