  61               	sub_start: | $0165
  62               	    * Z80 copied area object table from ROM to RAM
  63               	    * so MAIN CPU could access it. No need to do so
  64               	    * on 68K as it's one program.
  65 0042 41FA 0058 	    lea       sub_fn_jump_tbl_ROM,a0
  66 0046 43F9 0000 	    lea       sub_fn_jump_tbl_RAM,a1            | need a copy to patch in RAM
  66      0000 
  67 004c 7E1F      	    moveq     #0x20-1,d7
  68 004e 22D8      	1:  move.l    (a0)+,(a1)+
  69 0050 51CF FFFC 	    dbf       d7,1b   
  70 0054 207A 09D2 	    move.l       area_object_tbl_tbl_pointer(pc),a0            | need to copy for MAIN
  71 0058 43F9 0000 	    lea       area_object_tbl_tbl_RAM,a1
  71      0000 
  72 005e 7E0F      	    move.q    #16-1,d7
  73 0060 22D8      	2:  move.l    (a0)+,(a1)+
  74 0062 51CF FFFC 	    dbf       d7,2b   
  75               	    * Return here after initialisation
  76               	    * main function will call below regularly
  77 0066 4E75      	    rts
  78               	    
  79               	
  80               	xevious_sub_cpu: | $018A
  81               	restart_main_fn_loop:
  82 0068 303C 100F 	    move.w    #0x100F,d0                        | blue
  83 006c 4EB9 0000 	    jsr       osd_debug_hook
  83      0000 
  84               	
  85 0072 4DF9 0000 	    lea       sub_fn_jump_tbl_RAM,a6            | 32 functions
  85      0000 
  86 0078 7E1F      	    moveq     #32-1,d7
  87               	main_fn_loop:   
  88 007a 2016      	    move.l    (a6),d0                           | get jump address
  89 007c 670C      		jeq	1f		| skip if 0
  90 007e 48E7 0102 	    movem.l   d7/a6,-(a7)
  91 0082 2040      	    move.l	d0,a0
  92 0084 4E90      	    jsr       (a0)                          | call function
  93 0086 4CDF 4080 	    movem.l   (a7)+,d7/a6
  94               	1:
  95               	    | next table entry (we can't do move.l (a6)+,d0
  96               		| as code seems to rely on current a6 value)
  97 008a 584E      		addq.w	#4,a6
  98 008c 51CF FFEC 	    dbf       d7,main_fn_loop
